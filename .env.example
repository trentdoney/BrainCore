# BrainCore Configuration
# Copy this file to .env and fill in your values

# ── PostgreSQL (required) ──────────────────────────────────────────────────
# Connection string for PostgreSQL with pgvector extension
BRAINCORE_POSTGRES_DSN=postgresql://braincore:braincore@localhost:5432/braincore

# ── Data Paths ─────────────────────────────────────────────────────────────
# Root directory for your incident/knowledge vault
BRAINCORE_VAULT_ROOT=./data/vault

# Archive storage location
BRAINCORE_ARCHIVE_ROOT=./data/archive
BRAINCORE_ARCHIVE_BACKUP=./data/archive-backup

# Published memory output directory
BRAINCORE_PUBLISH_DIR=./data/memory/PRESERVED

# ── Local LLM (vLLM endpoints) ────────────────────────────────────────────
# Comma-separated list of name=url pairs, tried in order
# Set to empty or omit to use Claude CLI only
BRAINCORE_VLLM_ENDPOINTS=work=http://localhost:8006/v1
BRAINCORE_VLLM_HEALTH_TIMEOUT=3000
BRAINCORE_VLLM_REQUEST_TIMEOUT=120000

# ── Embedding Service ─────────────────────────────────────────────────────
# URL for the embedding endpoint (384-dim, e.g., all-MiniLM-L6-v2)
BRAINCORE_EMBED_URL=http://localhost:8900/embed
# Bearer token for authenticated embed endpoints (optional but recommended)
BRAINCORE_EMBED_AUTH_TOKEN=

# ── Telegram Alerts (optional) ────────────────────────────────────────────
# Bot token and chat ID for pipeline notifications
BRAINCORE_TELEGRAM_BOT_TOKEN=
BRAINCORE_TELEGRAM_CHAT_ID=

# ── Grafana (optional) ────────────────────────────────────────────────────
# For alert annotation extraction
BRAINCORE_GRAFANA_URL=http://localhost:3010
BRAINCORE_GRAFANA_API_KEY=

# ── Device Names (optional) ───────────────────────────────────────────────
# Comma-separated list of device names for entity extraction
BRAINCORE_KNOWN_DEVICES=server-a,server-b,workstation

# ── Extraction Limits (recommended) ────────────────────────────────────────
# Hard caps to keep large artifacts and semantic prompts bounded
BRAINCORE_MAX_SOURCE_BYTES=5242880
BRAINCORE_MAX_PROMPT_CHARS=120000
BRAINCORE_MAX_SEGMENTS_PER_PROMPT=50

# ── Codex/Claude/Discord Paths (optional) ────────────────────────────────
# Override default paths for Codex, Claude, and Discord source data.
# Leave empty to skip the corresponding extractor.
# Path to Codex session directory
BRAINCORE_CODEX_DIR=
# Path to Codex shared memory directory (empty to skip)
BRAINCORE_CODEX_SHARED_DIR=
# Path to PAI memory directory
BRAINCORE_PAI_MEMORY_DIR=
# Path to discord_digest SQLite database (empty to skip)
BRAINCORE_DISCORD_DB_PATH=

# ── Nightly Sync (optional) ───────────────────────────────────────────────
# Remote-to-local rsync source/dest for pulling CODEX_SHARED from another host.
# If unset, the nightly pipeline skips the codex-sync step.
# BRAINCORE_CODEX_SYNC_SRC=remote-host:/path/to/CODEX_SHARED/
# BRAINCORE_CODEX_SYNC_DEST=/path/to/local/CODEX_SHARED/

# Python interpreter for embedding + DB scripts (default: python3)
# Must have `psycopg` (v3) installed — the system python3 typically does not.
# Example:
# BRAINCORE_PYTHON=/path/to/venv/bin/python3
